<div class="cards-grid">

    <div class="card">

        <h3>🤖 BOT</h3>

        <p><strong>Status</strong></p>
        <span id="bot-state">
            <%= hasSnapshot ? snapshot.botState : "Aguardando..." %>
        </span>

        <hr>

        <p><strong>Broker</strong></p>
        <span id="bot-broker">
            <%= hasSnapshot ? snapshot.broker : "---" %>
        </span>

        <hr>

        <p><strong>Estratégia</strong></p>
        <span id="bot-strategy">
            <%= hasSnapshot ? snapshot.strategy : "---" %>
        </span>

    </div>

    <div class="card">

        <h3>💰 FINANCEIRO</h3>

        <p><strong>Lucro Total</strong></p>

        <span id="financial-profit">

            <%= hasSnapshot
                ? snapshot.financial.totalProfit.toFixed(2) + " USD"
                : "0.00 USD" %>

        </span>

        <hr>

        <p><strong>Trades</strong></p>

        <span id="financial-trades">

            <%= hasSnapshot
                ? snapshot.financial.totalTrades
                : 0 %>

        </span>

    </div>

    <div class="card">

        <h3>📈 PERFORMANCE</h3>

        <p><strong>Wins</strong></p>

        <span id="financial-wins">

            <%= hasSnapshot
                ? snapshot.financial.wins
                : 0 %>

        </span>

        <hr>

        <p><strong>Losses</strong></p>

        <span id="financial-losses">

            <%= hasSnapshot
                ? snapshot.financial.losses
                : 0 %>

        </span>

        <hr>

        <p><strong>Win Rate</strong></p>

        <span id="financial-winrate">

            <%

                let rate = "0.0";

                if(hasSnapshot){

                    const total = snapshot.financial.totalTrades;

                    rate = total > 0
                        ? ((snapshot.financial.wins / total) * 100).toFixed(1)
                        : "0.0";

                }

            %>

            <%= rate %>%

        </span>

    </div>

    <div class="card">

        <h3>🪙 MERCADO</h3>

        <p><strong>Ativo</strong></p>

        <span id="market-symbol">

            <%= hasSnapshot
                ? (snapshot.market?.display_name ||
                   snapshot.market?.underlying_symbol ||
                   "---")
                : "---" %>

        </span>

        <hr>

        <p><strong>Última atualização</strong></p>

        <span id="last-update">

            <%= hasSnapshot
                ? snapshot.timestamp.toLocaleTimeString()
                : "--:--:--" %>

        </span>

    </div>

</div>